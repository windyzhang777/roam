{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "paths": {
      "@/*": ["./src/*"],
      "@audiobook/shared": ["../shared/src"],
      "@/assets/*": ["./assets/*"],
      "@models/*": ["./src/models/*"],
      "@services/*": ["./src/services/*"],
      "@screens/*": ["./src/screens/*"],
      "@components/*": ["./src/components/*"],
      "@utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "metro.config.js", "App.tsx"],
  "exclude": ["node_modules", "metro.config.js"]
}
